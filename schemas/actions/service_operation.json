{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceOperationParams",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_@.-]+$",
      "description": "Systemd unit name"
    },
    "user_scope": {
      "type": "boolean",
      "default": false,
      "description": "If true, operate on user-level systemd units"
    }
  }
}
